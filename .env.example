# Production: Postgres connection string (e.g. Neon)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Secret used to sign login session tokens — set a long random string in production
JWT_SECRET="change-this-to-a-long-random-string"

# Optional: enables "scan vehicle photo" at check-in (auto-fills make/model/
# color/plate using Claude's vision). Get a key at console.anthropic.com.
# If left unset, the scan buttons will show a clear error instead of crashing.
ANTHROPIC_API_KEY=""
